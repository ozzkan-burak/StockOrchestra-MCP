{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "portfolio-manager": {
        "clusterId": "portfolio-cluster",
        "match": {
          "path": "/api/portfolio/{**rest}"
        },
        "transforms": [
          {
            "RequestHeader": "X-Forwarded-Path",
            "replace": "/api/portfolio/{**rest}"
          }
        ]
      },
      "analytical-store": {
        "clusterId": "analytical-cluster",
        "match": {
          "path": "/api/analytics/{**rest}"
        },
        "transforms": [
          {
            "RequestHeader": "X-Forwarded-Path",
            "replace": "/api/analytics/{**rest}"
          }
        ]
      },
      "price-discovery": {
        "clusterId": "price-discovery-cluster",
        "match": {
          "path": "/api/prices/{**rest}"
        },
        "transforms": [
          {
            "RequestHeader": "X-Forwarded-Path",
            "replace": "/api/prices/{**rest}"
          }
        ]
      }
    },
    "Clusters": {
      "portfolio-cluster": {
        "destinations": {
          "portfolio-manager": {
            "address": "http://localhost:5001"
          }
        }
      },
      "analytical-cluster": {
        "destinations": {
          "analytical-store": {
            "address": "http://localhost:5002"
          }
        }
      },
      "price-discovery-cluster": {
        "destinations": {
          "price-discovery": {
            "address": "http://localhost:5003"
          }
        }
      }
    }
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "StockOrchestra",
    "Audience": "StockOrchestra-Api"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:8080"
  }
}